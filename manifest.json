{
  "manifest_version": 3,
  "name": "SyncVerse",
  "description": "A lyric viewer for streaming services.",
  "version": "0.1",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://lrclib.net/*",
    "*://*.deezer.com/*",
    "*://*.spotify.com/*",
    "*://*.youtube.com/*"
  ],
  "action": {
    "default_icon": "icon.png"
  },
  "icons": {
    "48": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.deezer.com/*",
        "*://*.spotify.com/*",
        "*://*.youtube.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "syncverse@avictormorais.vercel.app"
    }
  }
}